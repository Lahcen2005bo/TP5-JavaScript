// Exercice3
let QUESTIONS = [
    ["Quelle est la capitale de la France ?", "Paris"],
    [" 5 + 5 ?", "10"],
];
function lancerQuiz() {
    let X = 0;
    for (let i = 0; i < QUESTIONS.length; i++) {
        let reponse = prompt(QUESTIONS[i][0]);
        if (reponse === QUESTIONS[i][1]) {
            window.alert("Vrai");
            X = X + 1;
        } else {
            window.alert("Faux");
        }
    }
    window.alert("Vous avez répondu à " +X+ " sur " + QUESTIONS.length + " questions correctement.");
}

